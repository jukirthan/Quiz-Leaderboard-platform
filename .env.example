# Local MySQL (or map Railway MYSQL* vars to these names)
DB_USER=root
DB_PASSWORD=your_password
DB_HOST=localhost
DB_NAME=your_db

# Railway MySQL plugin (auto-injected when linked)
# MYSQL_URL=mysql://user:pass@host:port/db
# MYSQLHOST=
# MYSQLPORT=3306
# MYSQLUSER=
# MYSQLPASSWORD=
# MYSQLDATABASE=
FLASK_DEBUG=True
JWT_SECRET_KEY=your_jwt_secret_key
JWT_ACCESS_TOKEN_EXPIRES_MINUTES=15

